title = "Líneas de tendencia por rival"
)
#Efecto del Beck SESION en las decisiones segun pago competitivo
library(ggplot2)
library(tidyverse)
# Convertir las variables relevantes a los tipos de datos adecuados
datosLimpios <- datosLimpios %>%
mutate(puntaje_beck = BECK_SESION, tipo_de_juego = as.factor(game_type), nivel_recompensa = as.factor(pay_competitive))
# Filtrar los datos solo para los juegos competitivo
datos_competir <- datosLimpios %>%
filter(tipo_de_juego == "individual")
# Calcular la cantidad de elecciones competitivas por sujeto y recompensa
datos_competir <- datos_competir %>%
group_by(nivel_recompensa, code, puntaje_beck, rival.f) %>%
dplyr::summarise(cantidad_elecciones = n())
datosLimpios %>%
group_by(code,rival.f,nivel_recompensa,puntaje_beck) %>%
mutate(n_trials = n(),
n_ind = sum(tipo_de_juego %in% "individual"),
p_ind = n_ind / n_trials,) %>%
ggplot(aes(x = puntaje_beck, y = p_ind, color = rival.f)) +
geom_point() +
#facet_wrap(~nivel_recompensa)+
geom_smooth(method = "lm", se = F, aes(color = nivel_recompensa)) +  # Añadir color a las líneas de tendencia
labs(
x = "Puntaje de Beck",
y = "Cantidad de elecciones individuales",
title = "Líneas de tendencia por nivel de recompensa"
)
# Crear el scatterplot con líneas de tendencia por nivel de recompensa
ggplot(datos_competir, aes(x = puntaje_beck, y = cantidad_elecciones, color = nivel_recompensa)) +
geom_point() +
facet_wrap(~rival.f)+
geom_smooth(method = "lm", se = TRUE, aes(color = nivel_recompensa)) +  # Añadir color a las líneas de tendencia
labs(
x = "Puntaje de Beck",
y = "Cantidad de elecciones individuales",
title = "Líneas de tendencia por nivel de recompensa"
)

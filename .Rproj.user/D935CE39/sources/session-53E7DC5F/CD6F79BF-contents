# Lista de variables psicológicas
variables_psico <- c("BECK_SESION", "LSAS_Total", "STAI_ESTADO", "STAI_RASGO", "PCA")

# Seleccionar solo una fila por participante, manteniendo un valor único por columna
data_resumen <- data %>%
  group_by(code) %>%
  summarise(
    edad = first(edad),
    across(all_of(variables_psico), ~ {
      valores <- unique(.x)
      if (length(valores) == 1) valores else NA  # asigna NA si hay más de un valor
    }),
    .groups = "drop"
  )
summary(data_resumen)

library(ggplot2)

ggplot(data_resumen, aes(x = edad, y = BECK_SESION)) +
  geom_point() +
  geom_smooth(method = "lm", se = TRUE, color = "blue") +
  labs(title = "Edad vs BECK", x = "Edad", y = "Puntaje BECK") +
  theme_minimal()

graficos <- lapply(variables_psico, function(var) {
  ggplot(data_resumen, aes_string(x = "edad", y = var)) +
    geom_point(alpha = 0.7) +
    geom_smooth(method = "lm", se = TRUE, color = "darkgreen") +
    labs(title = paste("Edad vs", var), x = "Edad", y = paste("Puntaje", var)) +
    theme_minimal()
})




